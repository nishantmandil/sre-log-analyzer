# ── LLM Provider ──────────────────────────────────────────────
# Options: groq | claude | gemini | ollama
LLM_PROVIDER=groq

# ── API Keys (fill in only the one you use) ───────────────────
ANTHROPIC_API_KEY=your_claude_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY="Put your Groq API key here. Get it from https://groq.com/console/account/api-keys"

# ── Ollama (local only, no API key needed) ────────────────────
OLLAMA_MODEL=llama3

# ── Logs Directory ────────────────────────────────────────────
# Path to folder containing your .log / .txt files
# Supports subdirectories (recursive scan)
LOGS_DIR=logs